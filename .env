# .env.local

# ----- Application Server -----
SERVER_PORT=8080

# ----- Main Database (mapped to localhost:5432) -----
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=user
DATABASE_PASSWORD=password
DATABASE_NAME=my_database
DATABASE_SSLMODE=disable

# ----- Events Database (mapped to localhost:5433) -----
EVENT_HOST=localhost
EVENT_PORT=5433
EVENT_USER=user
EVENT_PASS=password
EVENT_DATABASE_NAME=my_database
EVENT_SSLMODE=disable

# ----- Kafka Configuration -----
#on docker use container name kafka
#KAFKA_HOST=kafka:9092
#in localhost use host name
KAFKA_HOST=localhost:9092
KAFKA_TOPIC=messaging
KAFKA_GROUP_ID=messaging-group


SMS_PROVIDER_URL=https://api.sms-provider.com/send
SMS_API_KEY=your_sms_api_key_here
SMS_FROM_NUMBER=+1234567890

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_ADDRESS=noreply@yourcompany.com
EMAIL_API_KEY=your_email_api_key_here

LOGGER_LEVEL=debug
LOGGER_FILE_PATH=./logs/app.log
