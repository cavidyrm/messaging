# .env.local

SERVER_PORT=8080

DB_HOST=localhost
DB_PORT=5432
DB_USER=notif_user
DB_PASSWORD=notif_pass
DB_NAME=notification_db
DB_SSLMODE=disable

EVENT_DB_HOST=localhost
EVENT_DB_PORT=5433
EVENT_DB_USER=event_user
EVENT_DB_PASSWORD=event_pass
EVENT_DB_NAME=event_db
EVENT_DB_SSLMODE=disable

KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=notifications
KAFKA_GROUP_ID=notification-service

SMS_PROVIDER_URL=https://api.sms-provider.com/send
SMS_API_KEY=your_sms_api_key_here
SMS_FROM_NUMBER=+1234567890

EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_FROM_ADDRESS=noreply@yourcompany.com
EMAIL_API_KEY=your_email_api_key_here

LOGGER_LEVEL=debug
LOGGER_FILE_PATH=./logs/app.log
